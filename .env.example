# Copy this file to ".env" and fill in your values.

# The single shared password people enter to use the site.
SITE_PASSWORD=change-me-to-something-secret

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left unset, a random one is generated on each restart (logs everyone out on restart).
SESSION_SECRET=

# Port to listen on (default 3000).
PORT=3000

# Set to "production" when deploying behind HTTPS (enables secure cookies).
NODE_ENV=development
