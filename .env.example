# Copy this file to ".env" and fill in your values.

# There is no shared password — people log in with their Sleeper username,
# verified against the league below.

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left unset, a random one is generated on each restart (logs everyone out on restart).
SESSION_SECRET=

# Your Sleeper league ID — logins are verified against this league and votes are
# tracked by team name. Defaults to the configured league (1365139935241191424);
# only set this to point the app at a different league. Find it in the league URL:
#   https://sleeper.com/leagues/<THIS_IS_THE_ID>/...
# SLEEPER_LEAGUE_ID=

# Optional: how long (ms) to cache Sleeper lookups. Default 5 minutes.
# SLEEPER_CACHE_TTL_MS=300000

# Port to listen on (default 3000).
PORT=3000

# Set to "production" when deploying behind HTTPS (enables secure cookies).
NODE_ENV=development
